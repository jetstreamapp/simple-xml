{
  "$schema": "./node_modules/release-it/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}"
  },
  "github": {
    "release": true
  },
  "npm": {
    "skipChecks": true
  },
  "hooks": {
    "before:init": ["npm test"],
    "after:bump": "npm run build"
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "CHANGELOG.md",
      "addUnreleased": true,
      "addVersionUrl": true
    }
  }
}
